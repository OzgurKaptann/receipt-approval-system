# --- DB ---
POSTGRES_DB=ras
POSTGRES_USER=ras
POSTGRES_PASSWORD=ras_password
DATABASE_URL=postgresql+psycopg2://ras:ras_password@db:5432/ras

# --- App ---
ENV=dev
JWT_SECRET=CHANGE_ME_LONG_RANDOM
ACCESS_TOKEN_EXPIRE_MINUTES=720
STORAGE_DIR=/storage
PUBLIC_BASE_URL=https://YOUR_PUBLIC_URL

# --- Telegram ---
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME_NUMERIC
TELEGRAM_CB_SECRET=CHANGE_ME_LONG_RANDOM

# --- Slack ---
SLACK_BOT_TOKEN=CHANGE_ME
SLACK_SIGNING_SECRET=CHANGE_ME
SLACK_CHANNEL_ID=CHANGE_ME

# --- Email (SMTP) ---
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM="Receipt Ops <no-reply@example.com>"

# --- Deposit Provider ---
DEPOSIT_PROVIDER=SIMULATED
CRM_MT_DEPOSIT_URL=
CRM_MT_API_KEY=

# --- FX ---
FX_PROVIDER=TCMB
# FX_MODE=manual              # currently only 'manual' is supported
# FX_MANUAL_RATE=0.032        # TRY→USD rate, positive decimal, quantized to 6 dp
